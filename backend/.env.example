# HASAD Backend Environment Variables Template
# Copy this file to .env: cp .env.example .env

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
DATABASE_URL=postgresql+psycopg2://hasad:hasad_password@db:5432/hasad

# ============================================================================
# SECURITY - JWT TOKEN SIGNING
# ============================================================================
JWT_SECRET=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================================================
# EMAIL (SMTP) — required for registration + password reset
# Registration and password reset both send a 6-digit OTP via email.
# The server will return 503 if these are not set.
# ============================================================================
# Your SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Credentials for SMTP login
SMTP_USER=your-email@gmail.com
# Gmail App Passwords: copy the 16-char code with or without spaces — spaces are stripped automatically.
# Do NOT wrap the value in quotes here; dotenv quotes are handled by pydantic-settings.
SMTP_PASSWORD=your-app-password
# From address shown in outgoing emails
SMTP_FROM=noreply@hasad.app
# Use STARTTLS (recommended, leave true for port 587)
SMTP_TLS=true

# ============================================================================
# AUTH SETTINGS
# ============================================================================
# Email verification OTP validity (hours)
VERIFICATION_EXPIRE_HOURS=24
# Password reset OTP validity (hours)
PASSWORD_RESET_EXPIRE_HOURS=1

# Two-Factor Authentication (2FA)
TOTP_ISSUER=HASAD
TOTP_DIGITS=6
TOTP_INTERVAL=30
BACKUP_CODES_COUNT=10

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================
OPENWEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-flash

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=HASAD
APP_VERSION=1.0.0
DEBUG=false
