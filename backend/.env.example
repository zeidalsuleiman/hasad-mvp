# HASAD Backend Environment Variables Template

# Copy this file to .env in the same directory
# Command: cp .env.example .env

# ============================================================================
# DATABASE CONNECTION
# ============================================================================
DATABASE_URL=postgresql+psycopg2://hasad:hasad_password@db:5432/hasad

# ============================================================================
# SECURITY - JWT TOKEN SIGNING
# ============================================================================
JWT_SECRET=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ============================================================================
# EXTERNAL API KEYS - REPLACE WITH YOUR ACTUAL KEYS
# ============================================================================

# OpenWeatherMap API Key (Required for weather features)
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE

# Anthropic API Key (Required for AI Assistant)
# Get API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=HASAD
APP_VERSION=1.0.0
DEBUG=false
