# HASAD Environment Variables Template

# Copy this file to .env in the backend directory
# cp .env.example backend/.env

# Then fill in your actual API keys in backend/.env

# ============================================================================
# REQUIRED API KEYS
# ============================================================================
# 1. OpenWeatherMap API Key (for weather data)
#    Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# 2. Anthropic API Key (for AI assistant)
#    Get API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL database connection (managed by Docker Compose)
# For Docker: DATABASE_URL=postgresql+psycopg2://hasad:hasad_password@db:5432/hasad
DATABASE_URL=postgresql+psycopg2://hasad:hasad_password@db:5432/hasad

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret key (change this in production!)
JWT_SECRET=dev-secret-change-me-in-production

# ============================================================================
# OPTIONAL: APPLICATION SETTINGS
# ============================================================================
# APP_NAME=HASAD
# APP_VERSION=1.0.0
# DEBUG=false
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440

# ============================================================================
# INSTRUCTIONS
# ============================================================================
# 1. Copy this file to backend/.env:
#    cp .env.example backend/.env
#
# 2. Edit backend/.env and add your API keys:
#    OPENWEATHER_API_KEY=your_actual_key
#    ANTHROPIC_API_KEY=your_actual_key
#
# 3. Run Docker Compose:
#    docker-compose up --build
#
# 4. Access the application:
#    - Frontend: http://localhost:3000
#    - Backend API: http://localhost:8000
#    - API Docs: http://localhost:8000/docs
